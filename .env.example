# IG Edge One - Environment Configuration Template
# Copy this file to docker/.env and fill in your values

# Network Configuration
IPV4_ADDRESS=192.168.1.100
IPV6_ADDRESS=2001:db8::1
HOSTNAME=igedge-one
TIMEZONE=America/Sao_Paulo

# Security Credentials
PORTAINER_PASSWORD=your-secure-password-here
WG_ADMIN_PASSWORD=your-wireguard-password

# Docker Configuration
DOCKER_NETWORK=igedge-network
DATA_VOLUME=/opt/igedge
RESTART_POLICY=unless-stopped

# DNS Configuration
DNS_CACHE_SIZE=64m
DNS_RRSET_CACHE=128m
DNS_PREFETCH=yes
DNSSEC_ENABLED=yes

# Service Ports
LIBRESPEED_PORT=80
UPTIME_KUMA_PORT=3001
WIREGUARD_UDP_PORT=51820
WIREGUARD_TCP_PORT=51821
PORTAINER_PORT=9443
DNS_TCP_PORT=53
DNS_UDP_PORT=53
SSH_PORT=22

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_COMPRESSION=true

# Logging
LOG_RETENTION_DAYS=30
LOG_LEVEL=info

# Optional: Custom TLS Configuration
TLS_ENABLED=false
TLS_CERT_PATH=/etc/ssl/certs/server.crt
TLS_KEY_PATH=/etc/ssl/private/server.key